CONFIG_ENV=Profiles/guacamoleb_lineage_a15.env

DEVICE_NAME=oneplus_7_cn
DEVICE_CODENAME=guacamoleb

CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-
EXTRA_CMDS:LD=ld.lld LLVM=1 LLVM_IAS=1

KERNEL_SOURCE=https://github.com/snowwolf725/android_kernel_oneplus_sm8150.git
KERNEL_BRANCH=oneplus/LOS_SM8150_14.0
CLANG_SOURCE=https://github.com/repinger/android_clang-12
CLANG_BRANCH=main

GCC_GNU=true
GCC_64_SOURCE=https://github.com/LineageOS/android_prebuilts_gcc_linux-x86_aarch64_aarch64-linux-android-4.9
GCC_64_BRANCH=linage-19.1
GCC_32_SOURCE=https://android.googlesource.com/platform/prebuilts/gcc/linux-x86/x86/x86_64-linux-android-4.9
GCC_32_BRANCH=android12L-release

DEFCONFIG_SOURCE=
DEFCONFIG_NAME=lineage_sm8150_defconfig
DEFCONFIG_ORIGIN_DEFCONFIG=https://github.com/KawakazeNotFound/Kernel_Storage/raw/refs/heads/main/los-21boot.img

KERNELSU_SOURCE=https://raw.githubusercontent.com/tiann/KernelSU/refs/heads/main/kernel/setup.sh
KERNELSU_BRANCH=v0.9.5
KERNELSU_NAME=KernelSU

SUSFS_ENABLE=true
SUSFS_FIXED=false

AK3_SOURCE=https://github.com/osm0sis/AnyKernel3.git
AK3_BRANCH=master

BOOT_SOURCE=https://github.com/boot_author/android_kernel_codename/raw/refs/heads/main/rom/source_imgs/boot.img

LXC_ENABLE=false

HAVE_NO_DTBO=false
HAVE_NO_DTBO_TOOL=false

ROM_TEXT=rom_android
